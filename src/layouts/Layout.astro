---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
	title?: string;
	description?: string;
	/** Absolute or site-relative OG/Twitter image; omitted if not provided. */
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
	/**
	 * Pages built from full-width <Section> blocks (like the homepage) set
	 * this so <main> doesn't also apply a width constraint on top of each
	 * section's own container — see docs/DESIGN_SYSTEM.md. Simple content
	 * pages should leave this false to get the standard constrained <main>.
	 */
	fullBleed?: boolean;
	/**
	 * Override the language/direction of just <main>'s content, for a page
	 * whose body content is in a different language than the rest of the
	 * site (Header/Footer/skip-link stay in the site default). Omit for the
	 * normal case — every other page inherits ar/rtl from <html>.
	 */
	mainLang?: string;
	mainDir?: 'ltr' | 'rtl';
	/** Forwarded to <SEO>'s og:locale; only needed when it differs from the site default. */
	locale?: string;
	/**
	 * Override the whole page's <html lang dir> instead of just <main>'s —
	 * for a page that is entirely in a different language than the rest of
	 * the site (e.g. the English homepage on this Arabic-first site). Omit
	 * for the normal case.
	 */
	htmlLang?: string;
	htmlDir?: 'ltr' | 'rtl';
	/**
	 * Skip the global Arabic <Header>/<Footer> chrome so the page can render
	 * its own page-specific equivalents instead — only for a page that fully
	 * replaces that chrome itself (see the homepage). Omit for the normal case.
	 */
	hideChrome?: boolean;
	/** Skip-link label; only relevant when htmlLang overrides the site default. */
	skipLinkLabel?: string;
}

const {
	title = 'محمد الجابري',
	description = 'موقع شخصي لتوثيق مشاريعي، مقالاتي، وأعمالي في الطباعة ثلاثية الأبعاد.',
	image,
	imageAlt,
	noindex = false,
	jsonLd,
	fullBleed = false,
	mainLang,
	mainDir,
	locale,
	htmlLang = 'ar',
	htmlDir = 'rtl',
	hideChrome = false,
	skipLinkLabel = 'تخطَّ إلى المحتوى الرئيسي',
} = Astro.props;
---

<!doctype html>
<html lang={htmlLang} dir={htmlDir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<SEO
			title={title}
			description={description}
			image={image}
			imageAlt={imageAlt}
			noindex={noindex}
			jsonLd={jsonLd}
			locale={locale}
		/>

		<link rel="icon" href="/favicon.ico" />

		<slot name="head" />
	</head>

	<body id="top">
		<a class="skip-link" href="#main-content">{skipLinkLabel}</a>

		{!hideChrome && <Header />}
		<main id="main-content" class={fullBleed ? '' : 'container'} lang={mainLang} dir={mainDir}>
			<slot />
		</main>
		{!hideChrome && <Footer />}
	</body>
</html>
