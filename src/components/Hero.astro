---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Button from './Button.astro';
import Container from './Container.astro';

interface Cta {
	label: string;
	href: string;
}

interface Props {
	eyebrow: string;
	name: string;
	intro: string;
	primaryCta: Cta;
	secondaryCta: Cta;
	/** Real author photo — omitted today (none exists yet), falls back to
	 * the placeholder avatar below. Swap in once a photo is available. */
	image?: ImageMetadata;
	imageAlt?: string;
	/** Initials shown in the placeholder avatar when no photo is set. */
	initials?: string;
}

const {
	eyebrow,
	name,
	intro,
	primaryCta,
	secondaryCta,
	image,
	imageAlt,
	initials = 'م ج',
} = Astro.props;
---

<section class="hero" aria-label={name}>
	<Container class="hero-grid">
		<div class="hero-content">
			<p class="eyebrow">{eyebrow}</p>
			<h1>{name}</h1>
			<p class="intro">{intro}</p>
			<div class="cta-row">
				<Button href={primaryCta.href} variant="primary">{primaryCta.label}</Button>
				<Button href={secondaryCta.href} variant="secondary">{secondaryCta.label}</Button>
			</div>
		</div>

		{
			image ? (
				<Image class="photo" src={image} alt={imageAlt ?? ''} width={280} height={280} />
			) : (
				<div class="photo-placeholder" aria-hidden="true">
					<span>{initials}</span>
				</div>
			)
		}
	</Container>
</section>

<style>
	.hero {
		padding-block: var(--space-6);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		align-items: center;
		gap: var(--space-5);
	}

	.eyebrow {
		margin: 0 0 var(--space-1);
		color: var(--color-primary);
		font-size: 0.9rem;
		font-weight: 700;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.25rem, 1.8rem + 2vw, 3.5rem);
		line-height: 1.15;
	}

	.intro {
		margin: var(--space-3) 0 0;
		max-width: 38rem;
		color: var(--color-muted);
		font-size: 1.15rem;
		line-height: 1.7;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: var(--space-4);
	}

	.photo-placeholder,
	.photo {
		justify-self: center;
		width: min(280px, 60vw);
		aspect-ratio: 1;
		border-radius: var(--radius-large);
		border: 1px solid var(--color-border);
	}

	.photo-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			160deg,
			var(--color-surface),
			color-mix(in srgb, var(--color-primary) 12%, var(--color-surface))
		);
	}

	.photo {
		object-fit: cover;
	}

	.photo-placeholder span {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-muted);
	}

	@media (max-width: 800px) {
		.hero-grid {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.intro {
			margin-inline: auto;
		}

		.cta-row {
			justify-content: center;
		}

		.photo-placeholder,
		.photo {
			order: -1;
		}
	}
</style>
