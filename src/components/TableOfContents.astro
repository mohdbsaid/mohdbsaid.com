---
// Built from render()'s auto-extracted `headings` — Astro already slugs and
// IDs every heading in the rendered markdown, so these hrefs work with no
// extra plugin. Renders nothing for a post with fewer than 2 headings.
import type { MarkdownHeading } from 'astro';

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{
	items.length > 1 && (
		<nav class="toc" aria-labelledby="toc-heading">
			<p id="toc-heading" class="toc-title">
				محتويات المقال
			</p>
			<ol>
				{items.map((heading) => (
					<li class:list={[`depth-${heading.depth}`]}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ol>
		</nav>
	)
}

<style>
	.toc {
		margin-bottom: var(--space-4);
		padding: var(--space-3);
		background: var(--color-surface);
		border-radius: var(--radius-medium);
	}

	.toc-title {
		margin: 0 0 var(--space-1);
		font-size: 0.85rem;
		font-weight: 700;
	}

	ol {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.depth-3 {
		margin-inline-start: var(--space-3);
	}

	a {
		color: var(--color-muted);
		font-size: 0.9rem;
		transition: color 0.2s ease;
	}

	a:hover {
		color: var(--color-primary);
	}
</style>
