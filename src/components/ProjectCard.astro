---
// Project card for the homepage's Selected Work grid. Motion language
// (lift, shine sweep, radial glow, image scale, badge pop, pulsing action
// circle) is adapted from a Uiverse reference the project owner supplied,
// reworked for this page's dark glassmorphism palette — see
// docs/DECISIONS.md ADR-017. Relies on the CSS custom properties defined on
// `.page-bg` in src/pages/index.astro (falls back to sane defaults so it
// still renders reasonably if ever used somewhere those aren't set).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon, { type IconName } from './Icon.astro';

interface Props {
	title: string;
	description: string;
	status?: string;
	image?: ImageMetadata;
	imageAlt?: string;
	href?: string;
	category?: string;
	meta?: string;
	actionLabel?: string;
	/** Glyph shown in the media block when no real `image` is supplied. */
	icon?: IconName;
}

const {
	title,
	description,
	status,
	image,
	imageAlt = '',
	href,
	category,
	meta,
	actionLabel = 'View project',
	icon,
} = Astro.props;

const isCompleted = status?.toLowerCase() === 'completed';
const Surface = href ? 'a' : 'div';
const linkProps = href ? { href, 'aria-label': `${title} — ${actionLabel}` } : {};
---

<article class="project-card">
	<Surface class="card-surface" {...linkProps}>
		<span class="card-glow" aria-hidden="true"></span>
		<span class="card-shine" aria-hidden="true"></span>

		<div class="card-media">
			{
				image ? (
					<Image class="card-image" src={image} alt={imageAlt} width={480} height={300} />
				) : (
					<div class="card-media-fallback">
						{icon && <Icon name={icon} class="card-media-icon" />}
					</div>
				)
			}
			{status && <span class:list={['card-badge', { 'is-complete': isCompleted }]}>{status}</span>}
		</div>

		<div class="card-body">
			{category && <p class="card-category">{category}</p>}
			<h3 class="card-title">{title}</h3>
			<p class="card-description">{description}</p>
			{meta && <p class="card-meta">{meta}</p>}
		</div>

		<span class="card-action" aria-hidden="true">
			<Icon name="arrow" />
		</span>
	</Surface>
</article>

<style>
	.project-card {
		height: 100%;
	}

	.card-surface {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		overflow: hidden;
		isolation: isolate;
		text-decoration: none;
		color: inherit;
		background: var(--glass-bg, rgba(255, 255, 255, 0.06));
		border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.1));
		border-radius: var(--radius-md, 1.25rem);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		transition:
			transform 0.45s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			box-shadow 0.45s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			border-color 0.35s ease,
			background-color 0.35s ease;
	}

	a.card-surface {
		cursor: pointer;
	}

	.card-surface:hover,
	.card-surface:focus-visible {
		transform: translateY(-10px);
		border-color: var(--glass-border-strong, rgba(255, 255, 255, 0.16));
		background: var(--glass-bg-strong, rgba(255, 255, 255, 0.08));
		box-shadow:
			var(--shadow-soft, 0 20px 50px -20px rgba(0, 0, 0, 0.5)),
			0 0 40px -14px var(--accent, #a78bfa);
	}

	.card-surface:active {
		transform: translateY(-5px) scale(0.98);
	}

	/* Radial glow — fades in behind the media block on hover/focus. */
	.card-glow {
		position: absolute;
		inset: -10% -10% auto -10%;
		height: 65%;
		background: radial-gradient(circle at 50% 0%, rgba(167, 139, 250, 0.35), transparent 70%);
		opacity: 0;
		transition: opacity 0.5s ease;
		pointer-events: none;
		z-index: 0;
	}

	.card-surface:hover .card-glow,
	.card-surface:focus-visible .card-glow {
		opacity: 1;
	}

	/* Diagonal shine sweep — only plays while hovered/focused. */
	.card-shine {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			115deg,
			transparent 40%,
			rgba(255, 255, 255, 0.16) 50%,
			transparent 60%
		);
		background-size: 250% 250%;
		background-position: -50% -50%;
		opacity: 0;
		pointer-events: none;
		z-index: 1;
	}

	.card-surface:hover .card-shine,
	.card-surface:focus-visible .card-shine {
		opacity: 1;
		animation: card-shine 3s linear infinite;
	}

	@keyframes card-shine {
		0% {
			background-position: -150% -150%;
		}
		100% {
			background-position: 150% 150%;
		}
	}

	.card-media {
		position: relative;
		z-index: 1;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-radius: calc(var(--radius-md, 1.25rem) - 1px) calc(var(--radius-md, 1.25rem) - 1px) 0 0;
	}

	.card-image,
	.card-media-fallback {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	.card-media-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			135deg,
			var(--accent-strong, #7c3aed),
			var(--accent, #a78bfa) 60%,
			#4f46e5
		);
	}

	.card-media-icon {
		width: 2.75rem;
		height: 2.75rem;
		color: rgba(255, 255, 255, 0.85);
	}

	.card-surface:hover .card-image,
	.card-surface:hover .card-media-fallback,
	.card-surface:focus-visible .card-image,
	.card-surface:focus-visible .card-media-fallback {
		transform: translateY(-5px) scale(1.03);
	}

	/* Sits on top of the (often bright) media block, so it needs a solid-ish
	   dark backing rather than a translucent tint — a low-opacity color wash
	   loses contrast against an arbitrary gradient/photo behind it. */
	.card-badge {
		position: absolute;
		top: 1rem;
		inset-inline-end: 1rem;
		z-index: 2;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.35rem 0.9rem;
		border-radius: 999px;
		letter-spacing: 0.02em;
		white-space: nowrap;
		background: rgba(10, 10, 30, 0.62);
		color: var(--accent-soft, #c4b5fd);
		border: 1px solid rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		opacity: 0.94;
		transform: translateY(0) scale(1);
		transition:
			transform 0.35s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)) 0.05s,
			opacity 0.35s ease 0.05s,
			background-color 0.3s ease;
	}

	.card-badge.is-complete {
		color: #86efac;
		border-color: rgba(74, 222, 128, 0.35);
	}

	.card-surface:hover .card-badge,
	.card-surface:focus-visible .card-badge {
		opacity: 1;
		transform: translateY(-2px) scale(1.05);
	}

	.card-body {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: 0.5rem;
		padding: 1.5rem 1.5rem 4rem;
	}

	.card-category {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent, #a78bfa);
	}

	.card-title {
		font-size: 1.125rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--ink, #fff);
	}

	.card-description {
		flex: 1;
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--ink-muted, rgba(255, 255, 255, 0.72));
	}

	.card-meta {
		font-size: 0.8125rem;
		color: var(--ink-subtle, rgba(255, 255, 255, 0.5));
	}

	.card-action {
		position: absolute;
		inset-inline-end: 1.5rem;
		bottom: 1.5rem;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 50%;
		background: rgba(167, 139, 250, 0.14);
		border: 1px solid rgba(167, 139, 250, 0.25);
		color: var(--accent, #a78bfa);
		transition:
			transform 0.4s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			background-color 0.3s ease,
			color 0.3s ease;
	}

	.card-action :global(svg) {
		width: 1.1rem;
		height: 1.1rem;
		transition: transform 0.4s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	.card-surface:hover .card-action,
	.card-surface:focus-visible .card-action {
		background: var(--accent, #a78bfa);
		color: #fff;
		animation: card-pulse 1.5s ease-in-out infinite;
	}

	.card-surface:hover .card-action :global(svg),
	.card-surface:focus-visible .card-action :global(svg) {
		transform: translate(2px, -2px);
	}

	@keyframes card-pulse {
		0%,
		100% {
			box-shadow: 0 0 0 0 rgba(167, 139, 250, 0.45);
		}
		50% {
			box-shadow: 0 0 0 8px rgba(167, 139, 250, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.card-surface,
		.card-image,
		.card-media-fallback,
		.card-badge,
		.card-action,
		.card-action :global(svg) {
			transition: none;
		}
		.card-surface:hover,
		.card-surface:focus-visible,
		.card-surface:active {
			transform: none;
		}
		.card-surface:hover .card-image,
		.card-surface:hover .card-media-fallback,
		.card-surface:focus-visible .card-image,
		.card-surface:focus-visible .card-media-fallback {
			transform: none;
		}
		.card-shine,
		.card-surface:hover .card-action,
		.card-surface:focus-visible .card-action {
			animation: none;
		}
	}
</style>
