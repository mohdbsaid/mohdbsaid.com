---
// Visual breadcrumb trail only. Its BreadcrumbList JSON-LD is built by the
// page and passed through PageLayout's `jsonLd` prop instead of being
// rendered here — see docs/SEO.md rule 6 (one place for JSON-LD: <SEO />).
import type { BreadcrumbItem } from '../types';

interface Props {
	items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="مسار التنقل">
	<ol>
		{
			items.map((item, index) => (
				<li aria-current={!item.href ? 'page' : undefined}>
					{item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
					{index < items.length - 1 && (
						<span class="separator" aria-hidden="true">
							‹
						</span>
					)}
				</li>
			))
		}
	</ol>
</nav>

<style>
	.breadcrumbs {
		margin-bottom: var(--space-3);
		font-size: 0.9rem;
	}

	ol {
		display: flex;
		flex-wrap: wrap;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		display: flex;
		align-items: center;
		gap: var(--space-1);
		color: var(--color-muted);
	}

	li[aria-current='page'] {
		color: var(--color-text);
	}

	a {
		color: var(--color-muted);
		transition: color 0.2s ease;
	}

	a:hover {
		color: var(--color-primary);
	}

	.separator {
		margin-inline: var(--space-1);
	}
</style>
