---
interface Props {
	id: string;
	eyebrow?: string;
	title: string;
	description?: string;
	/** Use 1 for a page's single main heading (e.g. via PageLayout); defaults to 2 for section headings within a page. */
	level?: 1 | 2;
}

const { id, eyebrow, title, description, level = 2 } = Astro.props;
const Heading = level === 1 ? 'h1' : 'h2';
---

<div class="heading">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<Heading id={id}>{title}</Heading>
	{description && <p class="description">{description}</p>}
</div>

<style>
	.heading {
		max-width: 46rem;
		margin-bottom: var(--space-4);
	}

	.eyebrow {
		margin: 0 0 var(--space-1);
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
	}

	.heading :is(h1, h2) {
		margin: 0;
		font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
		line-height: 1.3;
	}

	.description {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 1.05rem;
	}
</style>
