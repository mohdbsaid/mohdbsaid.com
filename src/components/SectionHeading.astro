---
interface Props {
	id: string;
	eyebrow?: string;
	title: string;
	description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<div class="heading">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2 id={id}>{title}</h2>
	{description && <p class="description">{description}</p>}
</div>

<style>
	.heading {
		max-width: 46rem;
		margin-bottom: var(--space-4);
	}

	.eyebrow {
		margin: 0 0 var(--space-1);
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
	}

	h2 {
		margin: 0;
		font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
		line-height: 1.3;
	}

	.description {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 1.05rem;
	}
</style>
