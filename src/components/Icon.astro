---
// Minimal bespoke line-icon set (stroke-only, 24x24) used by the homepage.
// Replaces a Font Awesome CDN dependency that shipped ~350KB to render six
// glyphs — see docs/DECISIONS.md ADR-016. Add new names here as needed
// rather than reaching for an icon library for a handful of marks.
export type IconName = 'mail' | 'message' | 'print' | 'shield' | 'factory' | 'droplet';

interface Props {
	name: IconName;
	class?: string;
}

const { name, class: className } = Astro.props;
---

<svg
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.6"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	focusable="false"
>
	{
		name === 'mail' && (
			<>
				<rect x="3" y="5" width="18" height="14" rx="2" />
				<polyline points="3 7 12 13 21 7" />
			</>
		)
	}
	{
		name === 'message' && (
			<>
				<rect x="3" y="4" width="18" height="13" rx="4" />
				<polyline points="8 17 8 21 12 17" />
			</>
		)
	}
	{
		name === 'print' && (
			<>
				<polyline points="6 9 6 3 18 3 18 9" />
				<rect x="4" y="9" width="16" height="8" rx="1.5" />
				<rect x="8" y="14" width="8" height="6" />
			</>
		)
	}
	{name === 'shield' && <polygon points="12 3 19 6 19 11 12 21 5 11 5 6" />}
	{name === 'factory' && <polygon points="3 21 3 10 8 13 8 10 13 13 13 10 19 6 19 21" />}
	{name === 'droplet' && <path d="M12 2C12 2 5 12 5 16a7 7 0 0 0 14 0c0-4-7-14-7-14Z" />}
</svg>
