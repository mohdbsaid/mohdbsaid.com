---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Card from '../../../components/Card.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { formatArabicDate } from '../../../utils/formatDate';
import type { BreadcrumbItem } from '../../../types';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	const categories = [...new Set(posts.map((post) => post.data.category))];

	return categories.map((category) => ({
		params: { category },
		props: { posts: posts.filter((post) => post.data.category === category) },
	}));
}

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { category } = Astro.params;
const { posts } = Astro.props;

posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const title = `تصنيف: ${category}`;
const description = `مقالات ضمن تصنيف «${category}».`;

const breadcrumbItems: BreadcrumbItem[] = [
	{ label: 'الرئيسية', href: '/' },
	{ label: 'المدونة', href: '/blog' },
	{ label: category ?? '' },
];
---

<PageLayout title={title} description={description} eyebrow="المدونة">
	<Breadcrumbs items={breadcrumbItems} />

	<div class="card-grid">
		{
			posts.map((post) => (
				<Card
					kind="مقالة"
					title={post.data.title}
					description={post.data.description}
					meta={formatArabicDate(post.data.publishDate)}
					href={`/blog/${post.id}`}
					image={post.data.cover}
					imageAlt={post.data.coverAlt}
				/>
			))
		}
	</div>
</PageLayout>

<style>
	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-3);
	}

	@media (max-width: 800px) {
		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
