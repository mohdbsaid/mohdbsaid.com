---
// English/LTR homepage — deliberately bypasses the site's global Arabic
// <Header>/<Footer> chrome (via Layout's hideChrome) and renders the shared
// <PersonalPortfolio> template instead. This page owns only English copy
// and Layout wiring; markup/CSS/behavior live in PersonalPortfolio.astro so
// this page and src/pages/ar/index.astro stay one shared design, not two
// separate websites — see docs/DECISIONS.md ADR-019.
import Layout from '../layouts/Layout.astro';
import PersonalPortfolio from '../components/PersonalPortfolio.astro';
import { selectedWork } from '../data/selectedWork';

const title = 'Mohammed Al-Jabri — Additive Manufacturing & 3D Printing Specialist';
const description =
	'Mohammed Al-Jabri is an additive manufacturing and 3D printing specialist with six years of experience across printer operation, calibration, maintenance, CAD design, and technical training.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';
const email = 'mohdbsaid@outlook.com';
const whatsapp = 'https://wa.me/96891899818';

const jsonLd = [
	{
		'@type': 'Person',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		description,
		jobTitle: 'Additive Manufacturing & 3D Printing Specialist',
		email: `mailto:${email}`,
	},
	{
		'@type': 'WebSite',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		inLanguage: 'en',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	htmlLang="en"
	htmlDir="ltr"
	hideChrome
	skipLinkLabel="Skip to main content"
	locale="en_US"
>
	<Fragment slot="head">
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="alternate" hreflang="en" href={new URL('/', siteUrl)} />
		<link rel="alternate" hreflang="ar" href={new URL('/ar', siteUrl)} />
		<link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl)} />
	</Fragment>

	<PersonalPortfolio
		dir="ltr"
		email={email}
		whatsapp={whatsapp}
		nav={{ logo: 'Mohammed Al-Jabri', work: 'Work', about: 'About', contact: 'Contact' }}
		hero={{
			name: 'Mohammed Al-Jabri',
			initials: 'MA',
			role: 'Additive Manufacturing & 3D Printing Specialist',
			intro:
				'I work across printer operation, calibration, and CAD design, turning ideas into physical parts. I also train educators, students, and teams to do the same.',
			emailLabel: 'Email',
			whatsappLabel: 'WhatsApp',
		}}
		work={{
			eyebrow: 'Work',
			heading: 'Selected Work',
			projects: selectedWork.map((item) => ({ icon: item.icon, ...item.en })),
		}}
		about={{
			eyebrow: 'About',
			heading: 'About',
			stats: [
				{ value: 32, suffix: '+', label: 'Projects' },
				{ value: 63, suffix: '', label: 'Workshops' },
				{ value: 1340, suffix: '+', label: 'Beneficiaries' },
				{ value: 6, suffix: '', label: 'Years of Experience' },
			],
		}}
		contact={{
			eyebrow: 'Contact',
			heading: 'Let’s work together',
			paragraph:
				'Open to conversations about additive manufacturing, training, and collaboration — reach me by email or WhatsApp.',
			whatsappDisplay: '+968 91899818',
		}}
		footer={`© ${new Date().getFullYear()} Mohammed Al-Jabri`}
	>
		<Fragment slot="about-paragraph">
			Six years of experience, <strong>over 32 real-world projects</strong> delivered, <strong
				>63 workshops</strong
			> facilitated, and <strong>1,340+</strong> beneficiaries trained in additive manufacturing. Hands-on
			experience in FDM printing, calibration, maintenance, CAD design, training, and post-processing.
		</Fragment>
	</PersonalPortfolio>
</Layout>
