---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Tag from '../components/Tag.astro';
import Button from '../components/Button.astro';
import StatGrid from '../components/StatGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import { selectedWork } from '../data/selectedWork';

const title = 'Mohammed Al-Jabri — 3D Printing & Additive Manufacturing Specialist';
const description =
	'Mohammed Al-Jabri helps organizations adopt digital fabrication — 3D printing training, maintenance, calibration, and applied engineering.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';

// TODO: replace with the real WhatsApp number before launch.
const whatsappHref = 'https://wa.me/00000000000';

const stats = [
	{ value: '6', label: 'Years of experience' },
	{ value: '63', label: 'Workshops delivered' },
	{ value: '1,340+', label: 'People trained' },
];

const specialties = ['Maintenance', 'Calibration', 'Training', 'Design', 'Post-processing'];

const expertise = [
	{
		title: '3D Printing',
		description: 'Running printers, preparing print files, and troubleshooting during production.',
	},
	{
		title: 'CAD Design',
		description: 'Designing and optimizing parts to print efficiently and hold up in real use.',
	},
	{
		title: 'Printer Maintenance',
		description:
			'Diagnosing faults, routine calibration, and part replacement to extend printer life.',
	},
	{
		title: 'Training',
		description: 'Hands-on workshops for beginners and enthusiasts, from setup to troubleshooting.',
	},
	{
		title: 'Digital Systems',
		description: 'Building tools and digital workflows that support design and manufacturing.',
	},
	{
		title: 'Engineering Content',
		description:
			'Documenting hands-on experience and lessons learned in a practical, applicable way.',
	},
];

const jsonLd = [
	{
		'@type': 'Person',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		description,
		jobTitle: '3D Printing & Additive Manufacturing Specialist',
	},
	{
		'@type': 'WebSite',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		inLanguage: 'en',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	mainLang="en"
	mainDir="ltr"
	locale="en_US"
>
	<Hero
		eyebrow="Hi, I'm"
		name="Mohammed Al-Jabri"
		intro="A 3D printing & additive manufacturing specialist helping organizations adopt digital fabrication — through hands-on training, maintenance, and applied engineering."
		primaryCta={{ label: 'Selected work', href: '#work' }}
		secondaryCta={{ label: 'Get in touch', href: '#contact' }}
		initials="MA"
	/>

	<Section id="profile">
		<SectionHeading
			id="profile-heading"
			eyebrow="Professional profile"
			title="6 years of hands-on experience in 3D printing & additive manufacturing"
			description="Across maintenance, calibration, training, design, and post-processing."
		/>

		<div class="stats-block">
			<StatGrid stats={stats} />
		</div>

		<ul class="tag-list">
			{
				specialties.map((specialty) => (
					<li>
						<Tag label={specialty} />
					</li>
				))
			}
		</ul>
	</Section>

	<Section id="expertise" surface>
		<SectionHeading id="expertise-heading" eyebrow="What I do" title="Areas of expertise" />
		<FeatureGrid items={expertise} />
	</Section>

	<Section id="work">
		<SectionHeading
			id="work-heading"
			eyebrow="Selected work"
			title="Recent client engagements"
			description="A few organizations I've worked with — details coming soon."
		/>

		<ul class="work-grid">
			{
				selectedWork.map((item) => (
					<li>
						<span class="client">{item.client}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</li>
				))
			}
		</ul>
	</Section>

	<Section id="contact" surface>
		<SectionHeading
			id="contact-heading"
			eyebrow="Get in touch"
			title="Let's build something"
			description="Reach out on WhatsApp — happy to talk training, maintenance, or a new project."
		/>
		<Button href={whatsappHref} variant="primary">Message on WhatsApp</Button>
	</Section>
</Layout>

<style>
	.stats-block {
		margin: var(--space-4) 0;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-1);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-3);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.work-grid li {
		padding: var(--space-3);
		background: var(--color-background);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-medium);
	}

	.work-grid .client {
		color: var(--color-primary);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.work-grid h3 {
		margin: var(--space-1) 0;
		font-size: 1.05rem;
	}

	.work-grid p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	@media (max-width: 800px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
