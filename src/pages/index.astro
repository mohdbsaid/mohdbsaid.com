---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import StatGrid from '../components/StatGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import { selectedWork } from '../data/selectedWork';

const title = 'Mohammed Al-Jabri — Additive Manufacturing Specialist';
const description =
	'Mohammed Al-Jabri is an additive manufacturing and 3D printing specialist based in Oman, working across printer operation, maintenance, CAD design, and technical training.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';

const stats = [
	{ value: '6+', label: 'Years of experience' },
	{ value: '63', label: 'Workshops delivered' },
	{ value: '1,340+', label: 'People trained' },
];

const expertise = [
	{
		title: 'Additive Manufacturing',
		description:
			'Practical experience in FDM 3D printing, material selection, slicing, production planning, and quality control.',
	},
	{
		title: 'Maintenance & Calibration',
		description:
			'Printer diagnostics, preventive maintenance, calibration, troubleshooting, and operational readiness.',
	},
	{
		title: 'CAD & Prototyping',
		description:
			'Turning ideas and functional requirements into manufacturable models, prototypes, and replacement parts.',
	},
	{
		title: 'Technical Training',
		description:
			'Designing and delivering practical learning experiences for educators, students, and technical teams.',
	},
];

const jsonLd = [
	{
		'@type': 'Person',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		description,
		jobTitle: 'Additive Manufacturing Specialist',
	},
	{
		'@type': 'WebSite',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		inLanguage: 'en',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	mainLang="en"
	mainDir="ltr"
	locale="en_US"
>
	<Hero
		eyebrow="Additive Manufacturing · Oman"
		name="Mohammed Al-Jabri"
		intro="Designing, building, and teaching digital manufacturing — I help turn ideas into physical products through additive manufacturing, engineering workflows, technical training, and practical experimentation."
		primaryCta={{ label: 'View selected work', href: '#work' }}
		secondaryCta={{ label: 'Contact me', href: '#contact' }}
		initials="MA"
	/>

	<Section id="about">
		<SectionHeading
			id="about-heading"
			eyebrow="About"
			title="Building practical systems around physical production."
		/>

		<div class="stats-block">
			<StatGrid stats={stats} />
		</div>

		<div class="about-copy">
			<p>
				I am an additive manufacturing and 3D printing specialist with hands-on experience in
				printer operation, maintenance, calibration, CAD design, technical training, and
				post-processing.
			</p>

			<p>
				My work focuses on making advanced manufacturing tools more practical, understandable, and
				useful for workshops, educators, businesses, and individual creators.
			</p>
		</div>
	</Section>

	<Section id="expertise" surface>
		<SectionHeading
			id="expertise-heading"
			eyebrow="Expertise"
			title="What I work on."
			description="A combination of technical execution, systems thinking, and practical education."
		/>
		<FeatureGrid items={expertise} />
	</Section>

	<Section id="work">
		<SectionHeading
			id="work-heading"
			eyebrow="Selected work"
			title="Projects in development."
			description="A selection of systems and engineering products currently being designed, tested, or documented."
		/>

		<ul class="work-grid">
			{
				selectedWork.map((item) => (
					<li>
						<span class="label">{item.label}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
						<span class="status">{item.status}</span>
					</li>
				))
			}
		</ul>
	</Section>

	<Section id="contact" surface>
		<SectionHeading
			id="contact-heading"
			eyebrow="Contact"
			title="Have a project, collaboration, or technical challenge?"
			description="I am open to discussions related to additive manufacturing, technical training, prototyping, and digital manufacturing systems."
		/>

		<div class="contact-actions">
			<Button href="mailto:hello@mohdbsaid.com" variant="primary">Send an email</Button>
			<Button href="https://github.com/mohdbsaid" variant="secondary">View GitHub</Button>
		</div>
	</Section>
</Layout>

<style>
	.stats-block {
		margin: var(--space-4) 0;
	}

	.about-copy p {
		margin: 0 0 var(--space-3);
		color: var(--color-muted);
		font-size: 1.05rem;
	}

	.about-copy p:last-child {
		margin-bottom: 0;
	}

	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-3);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.work-grid li {
		display: flex;
		flex-direction: column;
		padding: var(--space-3);
		background: var(--color-background);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-medium);
	}

	.work-grid .label {
		color: var(--color-primary);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.work-grid h3 {
		margin: var(--space-1) 0;
		font-size: 1.05rem;
	}

	.work-grid p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.work-grid .status {
		margin-top: auto;
		padding-top: var(--space-3);
		color: var(--color-muted);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	@media (max-width: 800px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
