---
// English/LTR homepage — deliberately bypasses the site's global Arabic
// <Header>/<Footer> chrome (via Layout's hideChrome) and renders the shared
// <PersonalPortfolio> template instead. This page owns only English copy
// and Layout wiring; markup/CSS/behavior live in PersonalPortfolio.astro so
// this page and src/pages/ar/index.astro stay one shared design, not two
// separate websites — see docs/DECISIONS.md ADR-019.
import Layout from '../layouts/Layout.astro';
import PersonalPortfolio from '../components/PersonalPortfolio.astro';
import { selectedWork } from '../data/selectedWork';

const title = 'Mohammed Al-Jabri — Additive Manufacturing & 3D Printing Specialist';
const description =
	'Mohammed Al-Jabri is an additive manufacturing specialist with 6+ years keeping FDM production reliable for government, energy, and industrial clients in Oman — calibration, root-cause diagnostics, technical training, and print-workflow optimization.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';
const email = 'mohdbsaid@outlook.com';
const whatsapp = 'https://wa.me/96891899818';

const jsonLd = [
	{
		'@type': 'Person',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		description,
		jobTitle: 'Additive Manufacturing & 3D Printing Specialist',
		email: `mailto:${email}`,
		knowsAbout: [
			'Additive Manufacturing',
			'FDM 3D Printing',
			'Printer Maintenance',
			'CAD Workflow',
			'Technical Training',
		],
	},
	{
		'@type': 'WebSite',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		inLanguage: 'en',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	htmlLang="en"
	htmlDir="ltr"
	hideChrome
	skipLinkLabel="Skip to main content"
	locale="en_US"
>
	<Fragment slot="head">
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="alternate" hreflang="en" href={new URL('/', siteUrl)} />
		<link rel="alternate" hreflang="ar" href={new URL('/ar', siteUrl)} />
		<link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl)} />
	</Fragment>

	<PersonalPortfolio
		dir="ltr"
		email={email}
		whatsapp={whatsapp}
		nav={{
			logo: 'Mohammed Al-Jabri',
			work: 'Work',
			experience: 'Experience',
			about: 'About',
			contact: 'Contact',
		}}
		hero={{
			name: 'Mohammed Al-Jabri',
			initials: 'MA',
			role: 'Additive Manufacturing & 3D Printing Specialist',
			intro:
				'I keep FDM production reliable — calibration, root-cause troubleshooting, and print-workflow optimization for government, energy, and industrial projects across Oman. Six years in, I’ve also trained more than 1,300 people and helped bring a locally built 3D printer to market.',
			emailLabel: 'Email',
			whatsappLabel: 'WhatsApp',
		}}
		work={{
			eyebrow: 'Work',
			heading: 'Selected Work',
			projects: selectedWork.map((item) => ({ icon: item.icon, ...item.en })),
		}}
		experience={{
			eyebrow: 'Experience',
			heading: 'Experience',
			roles: [
				{
					title: '3D Printing Specialist',
					company: 'Plamore Manufacture',
					period: 'Dec 2024 – Jan 2026',
					description:
						'Ran production-grade FDM systems for government and industrial clients — job prep, material selection, calibration, and root-cause diagnostics to keep output consistent.',
				},
				{
					title: '3D Printing Technician',
					company: '3D Factory',
					period: 'Sep 2020 – Nov 2024',
					description:
						'Prepared and optimized print jobs from CAD through slicing, delivering prototypes, educational models, and custom parts for institutional and industrial clients across Oman.',
				},
			],
		}}
		about={{
			eyebrow: 'About',
			heading: 'About',
			stats: [
				{ value: 32, suffix: '+', label: 'Projects' },
				{ value: 63, suffix: '', label: 'Workshops' },
				{ value: 1340, suffix: '+', label: 'Participants' },
				{ value: 6, suffix: '+', label: 'Years of Experience' },
			],
		}}
		contact={{
			eyebrow: 'Contact',
			heading: 'Let’s work together',
			paragraph:
				'Open to conversations about additive manufacturing, technical training, or your next production challenge — reach out by email or WhatsApp.',
			whatsappDisplay: '+968 91899818',
		}}
		footer={`© ${new Date().getFullYear()} Mohammed Al-Jabri`}
	>
		<Fragment slot="about-paragraph">
			I'm an additive manufacturing specialist with <strong>6+ years</strong> keeping FDM production reliable
			— calibration, root-cause diagnostics, and print-workflow optimization — for government, energy,
			education, and industrial clients. I've delivered <strong>63 training workshops</strong> to more
			than <strong>1,300 participants</strong> across every governorate in Oman, and contributed to developing
			and commercializing a locally built 3D printer. My background is in communications and electronics
			engineering, which shapes how I work: diagnose first, then fix.
		</Fragment>
	</PersonalPortfolio>
</Layout>
