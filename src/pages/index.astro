---
// English/LTR minimal homepage — deliberately bypasses the site's global
// Arabic <Header>/<Footer> chrome (via Layout's hideChrome) and renders its
// own page-specific header/footer, per docs decision to scope this redesign
// to the homepage only. See CLAUDE.md component rules.
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import { selectedWork } from '../data/selectedWork';

const title = 'Mohammed Al-Jabri — Additive Manufacturing & 3D Printing Specialist';
const description =
	'Mohammed Al-Jabri is an additive manufacturing and 3D printing specialist with six years of experience across printer operation, calibration, maintenance, CAD design, and technical training.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';
const email = 'mohdbsaid@outlook.com';
const github = 'https://github.com/mohdbsaid';

const jsonLd = [
	{
		'@type': 'Person',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		description,
		jobTitle: 'Additive Manufacturing & 3D Printing Specialist',
		email: `mailto:${email}`,
		sameAs: [github],
	},
	{
		'@type': 'WebSite',
		name: 'Mohammed Al-Jabri',
		url: siteUrl,
		inLanguage: 'en',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	htmlLang="en"
	htmlDir="ltr"
	hideChrome
	skipLinkLabel="Skip to main content"
	locale="en_US"
>
	<div class="minimal">
		<header class="mini-header">
			<Container class="mini-header-row">
				<span class="mini-name">Mohammed Al-Jabri</span>
				<nav aria-label="Primary">
					<a href="#work">Work</a>
					<a href="#about">About</a>
					<a href="#contact">Contact</a>
				</nav>
			</Container>
		</header>

		<Container>
			<section id="intro" class="intro" aria-label="Introduction">
				<div class="intro-text">
					<h1>Mohammed Al-Jabri</h1>
					<p class="role">Additive Manufacturing &amp; 3D Printing Specialist</p>
					<p class="intro-copy">
						I work across printer operation, calibration, and CAD design, turning ideas into
						physical parts. I also train educators, students, and teams to do the same.
					</p>
					<p class="intro-links">
						<a href={`mailto:${email}`}>{email}</a>
						<a href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
					</p>
				</div>

				<div class="portrait" aria-hidden="true">
					<span>MA</span>
				</div>
			</section>

			<section id="work" aria-labelledby="work-heading">
				<h2 id="work-heading">Selected Work</h2>

				<ul class="work-list">
					{
						selectedWork.map((item) => (
							<li>
								<span class="work-name">{item.title}</span>
								<span class="work-desc">{item.description}</span>
								<span class="work-status">{item.status}</span>
							</li>
						))
					}
				</ul>
			</section>

			<section id="about" aria-labelledby="about-heading">
				<h2 id="about-heading">About</h2>
				<p>
					Six years of experience, 63 workshops delivered, and 1,340+ beneficiaries trained in
					additive manufacturing. Hands-on experience in FDM printing, calibration, maintenance, CAD
					design, training, and post-processing.
				</p>
			</section>

			<section id="contact" aria-labelledby="contact-heading">
				<h2 id="contact-heading">Contact</h2>
				<p>
					Open to conversations about additive manufacturing, training, and collaboration — reach me
					by <a href={`mailto:${email}`}>email</a> or on{' '}
					<a href={github} target="_blank" rel="noopener noreferrer">GitHub</a>.
				</p>
			</section>
		</Container>

		<footer class="mini-footer">
			<Container>
				<p>&copy; {new Date().getFullYear()} Mohammed Al-Jabri</p>
			</Container>
		</footer>
	</div>
</Layout>

<style>
	.minimal {
		font-family:
			system-ui,
			-apple-system,
			'Segoe UI',
			sans-serif;
	}

	/* Header */
	.mini-header {
		border-bottom: 1px solid var(--color-border);
	}

	.mini-header-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		padding-block: var(--space-3);
	}

	.mini-name {
		font-weight: 600;
	}

	.mini-header nav {
		display: flex;
		gap: var(--space-3);
	}

	.mini-header nav a {
		color: var(--color-muted);
		font-size: 0.95rem;
		transition: color 0.2s ease;
	}

	.mini-header nav a:hover,
	.mini-header nav a:focus-visible {
		color: var(--color-text);
	}

	/* Intro */
	.intro {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
		padding-block: var(--space-6);
	}

	.intro-text {
		max-width: 34rem;
	}

	.intro h1 {
		margin: 0;
		font-size: clamp(1.75rem, 1.5rem + 1.2vw, 2.5rem);
		font-weight: 600;
		line-height: 1.2;
	}

	.role {
		margin: var(--space-1) 0 0;
		color: var(--color-muted);
		font-size: 1.05rem;
	}

	.intro-copy {
		margin: var(--space-3) 0 0;
		color: var(--color-text);
		line-height: 1.7;
	}

	.intro-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin: var(--space-3) 0 0;
	}

	.intro-links a {
		color: var(--color-primary);
	}

	.intro-links a:hover,
	.intro-links a:focus-visible {
		text-decoration: underline;
	}

	.portrait {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 120px;
		aspect-ratio: 1;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-medium);
		background: var(--color-surface);
	}

	.portrait span {
		color: var(--color-muted);
		font-size: 1.25rem;
		font-weight: 600;
	}

	/* Section headings shared by Work / About / Contact */
	section[id] {
		padding-block: var(--space-5);
		border-top: 1px solid var(--color-border);
	}

	section[id] h2 {
		margin: 0 0 var(--space-3);
		font-size: 1.1rem;
		font-weight: 600;
	}

	section[id] p {
		margin: 0;
		max-width: 40rem;
		color: var(--color-muted);
		line-height: 1.7;
	}

	section[id] p a {
		color: var(--color-primary);
	}

	section[id] p a:hover,
	section[id] p a:focus-visible {
		text-decoration: underline;
	}

	/* Selected work rows */
	.work-list {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.work-list li {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-1) var(--space-3);
		padding-block: var(--space-2);
		border-bottom: 1px solid var(--color-border);
	}

	.work-list li:first-child {
		padding-top: 0;
	}

	.work-list li:last-child {
		border-bottom: none;
	}

	.work-name {
		flex: 0 0 auto;
		min-width: 10rem;
		font-weight: 600;
	}

	.work-desc {
		flex: 1 1 20rem;
		color: var(--color-muted);
	}

	.work-status {
		flex: 0 0 auto;
		color: var(--color-muted);
		font-size: 0.85rem;
	}

	/* Footer */
	.mini-footer {
		border-top: 1px solid var(--color-border);
	}

	.mini-footer p {
		margin: 0;
		padding-block: var(--space-3);
		color: var(--color-muted);
		font-size: 0.85rem;
	}

	@media (max-width: 700px) {
		.intro {
			flex-direction: column-reverse;
			text-align: center;
		}

		.intro-text {
			max-width: none;
		}

		.intro-links {
			justify-content: center;
		}

		.work-list li {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-1);
		}

		.work-desc {
			flex: none;
		}
	}
</style>
