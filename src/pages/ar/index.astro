---
// Arabic/RTL counterpart of the homepage — same shared <PersonalPortfolio>
// template as src/pages/index.astro, own Arabic copy and Layout wiring.
// This is the real Arabic equivalent of the homepage (dark glassmorphism,
// same components, same interactions), not a lighter/different design —
// see docs/DECISIONS.md ADR-019. Uses this site's existing self-hosted
// "Thmanyah Sans" (already Arabic-capable — it's the default body font on
// every other Arabic page) instead of loading a second webfont.
import Layout from '../../layouts/Layout.astro';
import PersonalPortfolio from '../../components/PersonalPortfolio.astro';
import { selectedWork } from '../../data/selectedWork';

const title = 'محمد الجابري — أخصائي التصنيع الإضافي والطباعة ثلاثية الأبعاد';
const description =
	'محمد الجابري أخصائي تصنيع إضافي بخبرة تتجاوز ست سنوات في إدارة إنتاج الطباعة بتقنية FDM وصيانتها، لعملاء في القطاعين الحكومي والصناعي وقطاع الطاقة في عُمان، إلى جانب التدريب التقني وتحسين مسارات العمل.';
const siteUrl = Astro.site?.toString() ?? 'https://mohdbsaid.com';
const email = 'mohdbsaid@outlook.com';
const whatsapp = 'https://wa.me/96891899818';

const jsonLd = [
	{
		'@type': 'Person',
		name: 'محمد الجابري',
		url: `${siteUrl}/ar`,
		description,
		jobTitle: 'أخصائي التصنيع الإضافي والطباعة ثلاثية الأبعاد',
		email: `mailto:${email}`,
		knowsAbout: [
			'التصنيع الإضافي',
			'الطباعة بتقنية FDM',
			'صيانة الطابعات',
			'تصميم CAD',
			'التدريب التقني',
		],
	},
	{
		'@type': 'WebSite',
		name: 'محمد الجابري',
		url: `${siteUrl}/ar`,
		inLanguage: 'ar',
	},
];
---

<Layout
	title={title}
	description={description}
	jsonLd={jsonLd}
	fullBleed
	htmlLang="ar"
	htmlDir="rtl"
	hideChrome
	skipLinkLabel="تخطَّ إلى المحتوى الرئيسي"
	locale="ar_OM"
>
	<Fragment slot="head">
		<link rel="alternate" hreflang="ar" href={new URL('/ar', siteUrl)} />
		<link rel="alternate" hreflang="en" href={new URL('/', siteUrl)} />
		<link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl)} />
	</Fragment>

	<PersonalPortfolio
		dir="rtl"
		email={email}
		whatsapp={whatsapp}
		nav={{
			logo: 'محمد الجابري',
			work: 'الأعمال',
			experience: 'الخبرة',
			about: 'نبذة',
			contact: 'تواصل',
		}}
		hero={{
			name: 'محمد الجابري',
			initials: 'م ج',
			role: 'أخصائي التصنيع الإضافي والطباعة ثلاثية الأبعاد',
			intro:
				'على مدى ست سنوات، حافظتُ على استقرار خطوط إنتاج الطباعة بتقنية FDM عبر المعايرة الدقيقة وتشخيص الأعطال من أسبابها الجذرية وتحسين مسارات العمل، لعملاء في القطاعين الحكومي والصناعي وقطاع الطاقة داخل عُمان. كما دربت أكثر من 1,300 مشارك، وساهمت في تطوير طابعة ثلاثية الأبعاد عُمانية الصنع وطرحها تجاريًا.',
			emailLabel: 'البريد الإلكتروني',
			whatsappLabel: 'واتساب',
		}}
		work={{
			eyebrow: 'الأعمال',
			heading: 'أعمال مختارة',
			projects: selectedWork.map((item) => ({ icon: item.icon, ...item.ar })),
		}}
		experience={{
			eyebrow: 'الخبرة',
			heading: 'الخبرة المهنية',
			roles: [
				{
					title: 'أخصائي طباعة ثلاثية الأبعاد',
					company: 'Plamore Manufacture',
					period: 'ديسمبر 2024 – يناير 2026',
					description:
						'تشغيل وصيانة منظومات طباعة FDM في بيئة إنتاج فعلية لعملاء حكوميين وصناعيين، مع إعداد المهام واختيار المواد والمعايرة وتشخيص الأعطال من جذورها للحفاظ على ثبات جودة الإنتاج.',
				},
				{
					title: 'تقني طباعة ثلاثية الأبعاد',
					company: '3D Factory',
					period: 'سبتمبر 2020 – نوفمبر 2024',
					description:
						'إعداد وتحسين مهام الطباعة من التصميم بواسطة CAD إلى التقطيع البرمجي، وتسليم نماذج أولية ونماذج تعليمية وقطع مخصصة لعملاء مؤسسيين وصناعيين في عُمان.',
				},
			],
		}}
		about={{
			eyebrow: 'نبذة',
			heading: 'نبذة عني',
			stats: [
				{ value: 32, suffix: '+', label: 'مشاريع' },
				{ value: 63, suffix: '', label: 'ورش عمل' },
				{ value: 1340, suffix: '+', label: 'مشاركون' },
				{ value: 6, suffix: '+', label: 'سنوات الخبرة' },
			],
		}}
		contact={{
			eyebrow: 'تواصل',
			heading: 'لنعمل معًا',
			paragraph:
				'أرحّب بالتواصل بشأن مشاريع التصنيع الإضافي أو التدريب التقني أو أي تحدٍّ إنتاجي تعمل عليه — يمكنك الوصول إليّ عبر البريد الإلكتروني أو واتساب.',
			whatsappDisplay: '+968 91899818',
		}}
		footer={`© ${new Date().getFullYear()} محمد الجابري`}
	>
		<Fragment slot="about-paragraph">
			أعمل أخصائيًا في التصنيع الإضافي منذ أكثر من <strong>ست سنوات</strong>، حيث أحافظ على استقرار
			الإنتاج بتقنية FDM من خلال المعايرة وتشخيص الأعطال من أسبابها الجذرية وتحسين مسارات العمل،
			لعملاء في القطاعات الحكومية والصناعية والتعليمية وقطاع الطاقة. قدّمت{' '}
			<strong>63 ورشة تدريبية</strong>{' '}
			استفاد منها أكثر من <strong>1,300 مشارك</strong> في جميع محافظات عُمان، وساهمت في تطوير وتسويق طابعة
			ثلاثية الأبعاد عُمانية الصنع. تأسست خلفيتي على دبلوم في هندسة الاتصالات والإلكترونيات، وهو ما يوجّه
			نهجي في كل مشروع: التشخيص أولًا، ثم الحل.
		</Fragment>
	</PersonalPortfolio>
</Layout>
