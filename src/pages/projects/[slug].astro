---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/Button.astro';
import { formatArabicDate } from '../../utils/formatDate';

export async function getStaticPaths() {
	const projects = await getCollection('projects', ({ data }) => !data.draft);

	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const {
	title,
	description,
	category,
	publishDate,
	status,
	technologies,
	cover,
	coverAlt,
	githubUrl,
	demoUrl,
} = project.data;

const { Content } = await render(project);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd = {
	'@type': 'CreativeWork',
	name: title,
	description,
	url: canonicalUrl,
	dateCreated: publishDate.toISOString(),
	datePublished: publishDate.toISOString(),
	...(cover && { image: new URL(cover.src, Astro.site).toString() }),
	...(technologies && technologies.length > 0 && { keywords: technologies.join('، ') }),
	author: { '@type': 'Person', name: 'محمد الجابري' },
};
---

<PageLayout
	title={title}
	description={description}
	eyebrow={category}
	image={cover?.src}
	imageAlt={coverAlt}
	jsonLd={jsonLd}
>
	<a class="back-link" href="/projects">→ العودة إلى المشاريع</a>

	{
		cover && (
			<Image
				class="cover"
				src={cover}
				alt={coverAlt ?? ''}
				widths={[600, 1100]}
				sizes="(max-width: 800px) 100vw, 1100px"
				width={1100}
				height={619}
			/>
		)
	}

	<dl class="meta-list">
		<div>
			<dt>الفئة</dt>
			<dd>{category}</dd>
		</div>
		{
			status && (
				<div>
					<dt>الحالة</dt>
					<dd>{status}</dd>
				</div>
			)
		}
		<div>
			<dt>تاريخ النشر</dt>
			<dd>{formatArabicDate(publishDate)}</dd>
		</div>
		{
			technologies && technologies.length > 0 && (
				<div>
					<dt>الأدوات والتقنيات</dt>
					<dd>{technologies.join('، ')}</dd>
				</div>
			)
		}
	</dl>

	{
		(githubUrl || demoUrl) && (
			<div class="links-row">
				{githubUrl && (
					<Button href={githubUrl} variant="secondary">
						الكود المصدري
					</Button>
				)}
				{demoUrl && <Button href={demoUrl}>تجربة حية</Button>}
			</div>
		)
	}

	<div class="project-body">
		<Content />
	</div>
</PageLayout>

<style>
	.back-link {
		display: inline-block;
		margin-bottom: var(--space-3);
		color: var(--color-primary);
		font-weight: 700;
	}

	.cover {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: var(--radius-medium);
		margin-bottom: var(--space-4);
	}

	.meta-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin: 0 0 var(--space-4);
		padding: var(--space-3);
		background: var(--color-surface);
		border-radius: var(--radius-medium);
	}

	.meta-list dt {
		margin: 0 0 0.25rem;
		color: var(--color-muted);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.meta-list dd {
		margin-inline-start: 0;
		font-size: 0.95rem;
	}

	.links-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-5);
	}

	.project-body {
		max-width: 46rem;
	}

	.project-body :global(h2) {
		margin: var(--space-5) 0 var(--space-2);
		font-size: 1.3rem;
		line-height: 1.4;
	}

	.project-body :global(h2:first-child) {
		margin-top: 0;
	}

	.project-body :global(p) {
		margin: 0 0 var(--space-2);
		color: var(--color-text);
		line-height: 1.8;
	}
</style>
